{
  "name": "committen",
  "version": "0.1.2",
  "description": "Committen = commit + kitten. A pixel cat desktop pet who eats your git commits and pounces on apps that aren't on your work whitelist.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win",
    "pack": "electron-builder --dir"
  },
  "keywords": [
    "desktop-pet",
    "focus",
    "productivity",
    "electron",
    "pixel-cat",
    "kitten",
    "git",
    "commit"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "active-win": "^8.2.0"
  },
  "build": {
    "appId": "com.committen.app",
    "productName": "Committen",
    "directories": {
      "output": "build"
    },
    "files": [
      "src/**/*",
      "config.example.json",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/active-win/**/*",
      "src/monitor/minimize.ps1"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
