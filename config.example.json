{
  "_comment": "Committen 用户配置示例。复制为 config.json 后修改,config.json 优先级高于本文件。",

  "_whitelist_note": "active-win 在 Windows 上对部分应用返回'显示名'(如 'Claude'、'Windows Explorer')而非 .exe 文件名,所以白名单同时包含两种形式才稳妥。",

  "whitelist": [
    "Code.exe",
    "Cursor.exe",
    "Idea64.exe",
    "pycharm64.exe",
    "webstorm64.exe",

    "WindowsTerminal.exe",
    "Windows Terminal Host",
    "cmd.exe",
    "powershell.exe",

    "explorer.exe",
    "Windows Explorer",
    "Task Manager",
    "taskmgr.exe",
    "TextInputHost.exe",
    "SnippingTool.exe",
    "Snipping Tool",

    "Search",
    "SearchApp.exe",
    "SearchHost.exe",
    "SearchUI.exe",
    "StartMenuExperienceHost.exe",
    "ShellExperienceHost.exe",
    "ApplicationFrameHost.exe",
    "SystemSettings.exe",
    "LockApp.exe",

    "chrome.exe",
    "msedge.exe",
    "firefox.exe",

    "notepad.exe",
    "Notepad++.exe",

    "Committen.exe",
    "FocusCat.exe",
    "electron.exe",

    "Claude",
    "Claude.exe",
    "ClaudeDesktop.exe"
  ],

  "gitRepo": "C:\\path\\to\\your\\repo",

  "monitor": {
    "intervalMs": 1000,
    "eatDurationMs": 3000,
    "cooldownMs": 5000,
    "actuallyMinimize": false
  },

  "hunger": {
    "initial": 80,
    "decayPerMinute": 1,
    "commitReward": 30
  }
}
